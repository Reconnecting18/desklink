generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── AUTH & USERS ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  avatarUrl    String?
  role         String   @default("MEMBER") // "ADMIN" | "MEMBER" | "VIEWER"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces          WorkspaceMember[]
  ownedWorkspaces     Workspace[]              @relation("WorkspaceOwner")
  assignedTasks       Task[]                   @relation("TaskAssignee")
  createdTasks        Task[]                   @relation("TaskCreator")
  comments            Comment[]
  fileVersions        FileVersion[]
  whiteboardCollabs   WhiteboardCollaborator[]
  documentCollabs     DocumentCollaborator[]
}

// ─── WORKSPACES ───────────────────────────────────────────

model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members     WorkspaceMember[]
  projects    Project[]
  whiteboards Whiteboard[]
  mockups     Mockup[]
  documents   Document[]
  files       File[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  userId      String
  workspaceId String
  role        String   @default("MEMBER") // "ADMIN" | "MEMBER" | "VIEWER"
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// ─── WHITEBOARD ───────────────────────────────────────────

model Whiteboard {
  id          String   @id @default(uuid())
  title       String
  workspaceId String
  thumbnail   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  elements      WhiteboardElement[]
  collaborators WhiteboardCollaborator[]
}

model WhiteboardElement {
  id           String   @id @default(uuid())
  whiteboardId String
  type         String   // "rect", "ellipse", "line", "text", "freehand", "image", "sticky"
  data         String   // JSON string: position, size, style, points, content
  zIndex       Int      @default(0)
  lockedBy     String?  // userId if locked for editing
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)

  @@index([whiteboardId])
}

model WhiteboardCollaborator {
  id           String   @id @default(uuid())
  whiteboardId String
  userId       String
  permission   String   @default("edit") // "view" | "edit"
  joinedAt     DateTime @default(now())

  whiteboard Whiteboard @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([whiteboardId, userId])
}

// ─── MOCKUPS ──────────────────────────────────────────────

model Mockup {
  id          String   @id @default(uuid())
  title       String
  description String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  screens   MockupScreen[]
}

model MockupScreen {
  id        String   @id @default(uuid())
  mockupId  String
  name      String
  width     Int      @default(375)
  height    Int      @default(812)
  sortOrder Int      @default(0)
  elements  String   @default("[]") // JSON string: UI components tree
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mockup      Mockup             @relation(fields: [mockupId], references: [id], onDelete: Cascade)
  annotations MockupAnnotation[]

  @@index([mockupId])
}

model MockupAnnotation {
  id        String   @id @default(uuid())
  screenId  String
  x         Float
  y         Float
  content   String
  authorId  String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  screen MockupScreen @relation(fields: [screenId], references: [id], onDelete: Cascade)
}

// ─── PLANNER ──────────────────────────────────────────────

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  boards    Board[]
  tasks     Task[]
  events    CalendarEvent[]
}

model Board {
  id        String   @id @default(uuid())
  projectId String
  name      String
  createdAt DateTime @default(now())

  project Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]
}

model BoardColumn {
  id        String  @id @default(uuid())
  boardId   String
  name      String  // "To Do", "In Progress", "Done"
  sortOrder Int     @default(0)
  color     String?

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      String    @default("todo")
  priority    String    @default("MEDIUM") // "LOW" | "MEDIUM" | "HIGH" | "URGENT"
  dueDate     DateTime?
  projectId   String
  columnId    String?
  sortOrder   Int       @default(0)
  assigneeId  String?
  creatorId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column   BoardColumn? @relation(fields: [columnId], references: [id], onDelete: SetNull)
  assignee User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator  User         @relation("TaskCreator", fields: [creatorId], references: [id])
  labels   TaskLabel[]
  comments Comment[]

  @@index([projectId])
  @@index([columnId])
}

model TaskLabel {
  id     String @id @default(uuid())
  taskId String
  name   String
  color  String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, name])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  allDay      Boolean  @default(false)
  projectId   String
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

// ─── DOCUMENTS (Word, Excel, PowerPoint) ──────────────────

model Document {
  id          String   @id @default(uuid())
  title       String
  type        String   // "DOCUMENT" | "SPREADSHEET" | "PRESENTATION"
  workspaceId String
  content     String   @default("{}") // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace     Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  collaborators DocumentCollaborator[]
  versions      DocumentVersion[]

  @@index([workspaceId, type])
}

model DocumentVersion {
  id         String   @id @default(uuid())
  documentId String
  version    Int
  content    String   // JSON string
  createdBy  String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([documentId])
}

model DocumentCollaborator {
  id         String @id @default(uuid())
  documentId String
  userId     String
  permission String @default("edit")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
}

// ─── FILE SYNC ────────────────────────────────────────────

model File {
  id          String   @id @default(uuid())
  name        String
  mimeType    String
  size        Int      // bytes
  storagePath String
  workspaceId String
  parentId    String?  // for folder hierarchy
  isFolder    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parent    File?         @relation("FileTree", fields: [parentId], references: [id])
  children  File[]        @relation("FileTree")
  versions  FileVersion[]

  @@index([workspaceId])
  @@index([parentId])
}

model FileVersion {
  id          String   @id @default(uuid())
  fileId      String
  version     Int
  storagePath String
  size        Int
  uploadedBy  String
  createdAt   DateTime @default(now())

  file     File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploadedBy], references: [id])

  @@unique([fileId, version])
}

// ─── AI INTEGRATION ───────────────────────────────────────

model AiRequest {
  id          String   @id @default(uuid())
  type        String   // "summarize" | "generate" | "suggest"
  input       String   // JSON string
  output      String?  // JSON string
  status      String   @default("pending") // "pending" | "completed" | "failed"
  workspaceId String?
  userId      String
  durationMs  Int?
  createdAt   DateTime @default(now())
}
